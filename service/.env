# =============================================================================
# Ads Platform — Service 环境配置（开发环境）
# =============================================================================
# 此文件被 gitignore 排除，每个环境独立维护。
# 完整配置项说明见 .env.example。
# =============================================================================

# --- 应用 ---
APP_DEBUG=true
APP_URL=http://0.0.0.0:8788

# --- 数据库（MySQL 8.0） ---
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=ads
DB_USERNAME=root
DB_PASSWORD=

# --- Redis 7 ---
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_PASSWORD=

# --- JWT 认证 ---
JWT_SECRET=your-secret-key-change-me
JWT_TTL=86400

# --- Hashids ID 加解密 ---
HASHIDS_SALT=ads-platform-salt
HASHIDS_MIN_LENGTH=8

# --- 加密 ---
APP_ENCRYPTION_KEY=your-32-char-encryption-key-here

# --- Elasticsearch ---
SCOUT_DRIVER=elasticsearch
ES_HOST=127.0.0.1:9200
ES_INDEX=ads_platform
