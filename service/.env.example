# =============================================================================
# Ads Platform — Service Environment Configuration
# =============================================================================
# Copy this file to .env and fill in your values.
# Never commit .env to version control — it contains secrets.
# =============================================================================

# --- Application ---
# Enable debug mode — shows detailed errors (set false in production)
APP_DEBUG=false

# Base URL for the service (used in redirects, OAuth callbacks, etc.)
APP_URL=http://0.0.0.0:8788

# --- Database (MySQL 8.0) ---
# All tables use the erik_ prefix and BIGINT snowflake primary keys.
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=ads
DB_USERNAME=root
DB_PASSWORD=

# Enable persistent connections to avoid per-request handshake overhead
DB_PERSISTENT=false

# Connection timeout in seconds — keep low for fail-fast behavior
DB_TIMEOUT=3

# --- Redis 7 ---
# Used for: dashboard cache, rate limiting counters, queue, pub/sub
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_PASSWORD=

# --- JWT Authentication (erikwang2013/jwt-webman) ---
# Secret key for signing/verifying tokens — use a long random string
JWT_SECRET=
# Token lifetime in seconds (86400 = 24 hours)
JWT_TTL=86400

# --- Hashids (erikwang2013/hashids) ---
# API ID encryption — obfuscates database IDs in API responses
# Salt string for hash generation — change this to invalidate all existing hashes
HASHIDS_SALT=
# Minimum hash length (8 characters recommended for security)
HASHIDS_MIN_LENGTH=8

# --- Encryption (erikwang2013/encryption + encryptable) ---
# Master key for API-level and DB-field encryption (32+ characters)
APP_ENCRYPTION_KEY=
# Cipher algorithm — aes-128-ecb or aes-256-cbc
ENCRYPTION_CIPHER=aes-128-ecb
# Previous encryption keys for key rotation (comma-separated)
ENCRYPTION_PREVIOUS_KEYS=

# --- Elasticsearch (erikwang2013/webman-scout) ---
# Search driver — elasticsearch or meilisearch
SCOUT_DRIVER=elasticsearch
# ES cluster hosts (comma-separated for multi-node clusters)
ES_HOST=127.0.0.1:9200
# Index name prefix for this application
ES_INDEX=ads_platform

# =============================================================================
# Platform Credentials
# =============================================================================
# One set of credentials per ad platform adapter.
# Leave blank for platforms you don't use — they simply won't appear in
# the platform list or be available for account binding.
# =============================================================================

# --- 国内平台 (16) ---

# 巨量引擎 (ByteDance Ocean Engine)
JULIANG_APP_ID=
JULIANG_SECRET=

# 百度营销
BAIDU_APP_ID=
BAIDU_SECRET=

# 淘宝/阿里妈妈 (MD5 signature required)
TAOBAO_APP_KEY=
TAOBAO_SECRET=

# 腾讯广告 / 广点通 (nonce anti-replay)
TENCENT_APP_ID=
TENCENT_SECRET=

# 快手磁力引擎
KUAISHOU_APP_ID=
KUAISHOU_SECRET=

# 小红书蒲公英 / 聚光平台
XIAOHONGSHU_APP_KEY=
XIAOHONGSHU_SECRET=

# 微博粉丝通
WEIBO_APP_ID=
WEIBO_SECRET=

# B站花火
BILIBILI_APP_ID=
BILIBILI_SECRET=

# 优酷广告 (Alibaba MD5 signature — same as Taobao)
YOUKU_APP_KEY=
YOUKU_SECRET=

# 美团广告 (本地生活)
MEITUAN_APP_ID=
MEITUAN_SECRET=

# 知乎广告 (内容营销)
ZHIHU_APP_ID=
ZHIHU_SECRET=

# 360推广 (API Key + Sign headers)
QIHOO360_API_KEY=
QIHOO360_API_SECRET=

# 搜狗推广 (API Key + Sign headers)
SOGOU_API_KEY=
SOGOU_API_SECRET=

# 友盟 (API Key + MD5, report + oauth only — no campaign management)
UMENG_API_KEY=
UMENG_API_SECRET=

# 京东京准通 (JD Cloud MD5 signature)
JINGDONG_APP_KEY=
JINGDONG_SECRET=

# 拼多多 / 多多进宝 (custom PDD signature)
PINDUODUO_CLIENT_ID=
PINDUODUO_CLIENT_SECRET=

# --- 国际平台 (13) ---

# Google Ads (OAuth2 + GAQL + developer token required)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_DEVELOPER_TOKEN=

# YouTube Ads (Google Ads API, filtered to VIDEO campaigns)
# Uses GOOGLE_CLIENT_ID / GOOGLE_CLIENT_SECRET / GOOGLE_DEVELOPER_TOKEN above

# Meta Ads (Facebook + Instagram, Graph API v19)
META_APP_ID=
META_APP_SECRET=

# TikTok for Business (international — different API from Juliang)
TIKTOK_APP_ID=
TIKTOK_SECRET=

# LinkedIn Ads (Restli protocol, micro-dollars)
LINKEDIN_CLIENT_ID=
LINKEDIN_CLIENT_SECRET=

# Snapchat Ads (micro-dollars)
SNAPCHAT_CLIENT_ID=
SNAPCHAT_CLIENT_SECRET=

# Pinterest Ads (micro-dollars)
PINTEREST_APP_ID=
PINTEREST_APP_SECRET=

# Twitter/X Ads
TWITTER_CLIENT_ID=
TWITTER_CLIENT_SECRET=

# Amazon Ads (Login with Amazon + profile-based auth)
AMAZON_CLIENT_ID=
AMAZON_CLIENT_SECRET=

# The Trade Desk (DSP, HMAC-SHA256 signature)
THETRADEDESK_API_KEY=
THETRADEDESK_API_SECRET=

# Spotify Ads (audio advertising)
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=

# Twitch Ads (OAuth2 + Client-Id dual auth)
TWITCH_CLIENT_ID=
TWITCH_CLIENT_SECRET=

# Netflix Ads (OAuth2 client_credentials — machine to machine)
NETFLIX_CLIENT_ID=
NETFLIX_CLIENT_SECRET=
