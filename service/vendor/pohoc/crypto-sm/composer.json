{
  "name": "pohoc/crypto-sm",
  "description": "国密算法 SM2、SM3 和 SM4 的 PHP 版实现",
  "keywords": [
    "sm2",
    "sm3",
    "sm4",
    "crypto",
    "国密",
    "gm",
    "encryption"
  ],
  "license": "MIT",
  "homepage": "https://github.com/pohoc/crypto-sm",
  "authors": [
    {
      "name": "pohoc",
      "email": "po.hoc4@gmail.com",
      "homepage": "https://github.com/pohoc"
    }
  ],
  "support": {
    "issues": "https://github.com/pohoc/crypto-sm/issues",
    "source": "https://github.com/pohoc/crypto-sm"
  },
  "require": {
    "php": ">=8.0"
  },
  "require-dev": {
    "phpunit/phpunit": "^9.0"
  },
  "autoload": {
    "psr-4": {
      "CryptoSm\\": "src/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "CryptoSm\\Tests\\": "tests/"
    }
  },
  "config": {
    "optimize-autoloader": true,
    "preferred-install": "dist",
    "sort-packages": true
  },
  "minimum-stability": "stable",
  "prefer-stable": true
}