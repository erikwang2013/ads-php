# =============================================================================
# Ads Platform — Admin Panel Environment Configuration
# =============================================================================
# The admin panel is a standalone webman-admin v2 instance (port 8789).
# It serves the Vue 3 SPA and handles admin auth (RBAC + audit logging).
# Business data is accessed via the service API — see SERVICE_API_URL below.
# =============================================================================

# --- Application ---
# Enable debug mode — shows detailed errors (set false in production)
APP_DEBUG=true

# --- Service API ---
# Base URL of the user-facing business service API (webman v2 on :8788).
# All admin business queries (campaigns, reports, accounts, platforms, alerts)
# are proxied through ServiceProxy to this endpoint.
SERVICE_API_URL=http://127.0.0.1:8788/api/v1

# --- Database (MySQL 8.0) ---
# Stores admin-specific tables: admin_users, admin_roles, admin_audit_logs.
# Shares the same physical MySQL server as the service but uses separate
# table names (admin_* vs erik_*) for logical separation.
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=ads
DB_USERNAME=root
DB_PASSWORD=

# --- Redis 7 ---
# Used for: admin session storage, rate limiting, optional API response cache.
# Uses database 1 to isolate keys from the service (which uses database 0).
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_PASSWORD=

# --- JWT Authentication (erikwang2013/jwt-webman) ---
# Secret key for signing/verifying admin JWT tokens.
# Must differ from the service JWT_SECRET for security isolation.
JWT_SECRET=admin-jwt-secret-change-me
# Token lifetime in seconds (86400 = 24 hours)
JWT_TTL=86400
